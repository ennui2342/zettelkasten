{
  "manifest_version": 3,
  "name": "Ingest → zettelkasten",
  "version": "1.0",
  "description": "Send the current page to your local zettelkasten ingest server.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:7842/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ingest into zettelkasten",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
